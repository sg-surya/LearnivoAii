
/**
 * @fileoverview Firestore Security Rules for Sahayak AI application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each user has full control
 * over their own profile data, folders, and assets. No cross-user access is permitted
 * except where explicitly noted. Data validation is relaxed to allow for rapid
 * prototyping, focusing instead on secure authorization.
 *
 * Data Structure:
 * The data is organized hierarchically under the /userProfiles/{userId} node.
 * - /userProfiles/{userId}: Stores user profile information.
 * - /userProfiles/{userId}/folders/{folderId}: Stores folders created by the user.
 * - /userProfiles/{userId}/assets/{assetId}: Stores assets generated by the user.
 *
 * Key Security Decisions:
 * - User listing is disabled for privacy.
 * - Write access is strictly controlled by ownership.
 * - Data validation is minimal during the prototyping phase, focusing on authorization.
 *
 * Denormalization for Authorization:
 * No denormalization is needed as the path itself (/userProfiles/{userId}/...)
 * establishes ownership, and this is enforced using the `isOwner(userId)` function.
 *
 * Structural Segregation:
 * All user-specific data is stored under the /userProfiles/{userId} path, ensuring
 * clear segregation between users. There is no public data in this prototype.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @returns {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource.
     * @param {string} userId - The user ID to compare against the authenticated user's ID.
     * @returns {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource and it exists.
     *              This function is used for destructive operations like update and delete.
     * @param {string} userId - The user ID to compare against the authenticated user's ID.
     * @returns {boolean} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for user profile documents.
     * @path /userProfiles/{userProfileId}
     * @allow (create) - Authenticated user with matching `userProfileId` can create their own profile.
     * @allow (get, update, delete) - Authenticated user can get, update, and delete their own profile.
     * @deny (create) - Authenticated user cannot create a profile for another user.
     * @deny (get, update, delete) - Authenticated user cannot get, update, or delete another user's profile.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /userProfiles/{userProfileId} {
      allow get: if isOwner(userProfileId);
      allow list: if false; // User listing is disabled.
      allow create: if isOwner(userProfileId) && request.resource.data.id == userProfileId;
      allow update: if isExistingOwner(userProfileId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userProfileId);
    }

    /**
     * @description Rules for folders within a user profile.
     * @path /userProfiles/{userProfileId}/folders/{folderId}
     * @allow (create) - Authenticated user can create folders under their own profile.
     * @allow (get, list, update, delete) - Authenticated user can get, list, update, and delete folders under their own profile.
     * @deny (create) - Authenticated user cannot create folders under another user's profile.
     * @deny (get, list, update, delete) - Authenticated user cannot get, list, update, or delete folders under another user's profile.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /userProfiles/{userProfileId}/folders/{folderId} {
      allow get: if isOwner(userProfileId);
      allow list: if isOwner(userProfileId);
      allow create: if isOwner(userProfileId);
      allow update: if isExistingOwner(userProfileId);
      allow delete: if isExistingOwner(userProfileId);
    }

    /**
     * @description Rules for assets within a user profile.
     * @path /userProfiles/{userProfileId}/assets/{assetId}
     * @allow (create) - Authenticated user can create assets under their own profile.
     * @allow (get, list, update, delete) - Authenticated user can get, list, update, and delete assets under their own profile.
     * @deny (create) - Authenticated user cannot create assets under another user's profile.
     * @deny (get, list, update, delete) - Authenticated user cannot get, list, update, or delete assets under another user's profile.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /userProfiles/{userProfileId}/assets/{assetId} {
      allow get: if isOwner(userProfileId);
      allow list: if isOwner(userProfileId);
      allow create: if isOwner(userProfileId);
      allow update: if isExistingOwner(userProfileId);
      allow delete: if isExistingOwner(userProfileId);
    }

    /**
     * @description Rules for visual aid feedback.
     * @path /visualAidFeedbacks/{feedbackId}
     * @allow (create) - Any authenticated user can create feedback.
     * @deny (read, update, delete) - Nobody can read, update or delete feedback to ensure privacy.
     */
    match /visualAidFeedbacks/{feedbackId} {
      allow read, update, delete: if false;
      allow create: if isSignedIn();
    }

    /**
     * @description Rules for asset feedback.
     * @path /assetFeedbacks/{feedbackId}
     * @allow (create) - Any authenticated user can create feedback.
     * @deny (read, update, delete) - Nobody can read, update or delete feedback to ensure privacy.
     */
    match /assetFeedbacks/{feedbackId} {
      allow read, update, delete: if false;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
  }
}
